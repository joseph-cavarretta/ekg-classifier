# EKG Classifier Configuration
# Copy this file to .env and fill in your values

# Data paths (optional - defaults work for standard setup)
DATA_DIR=data
TRAIN_FILE=mitbih_train.csv.gz
TEST_FILE=mitbih_test.csv.gz
OUTPUT_DIR=output

# GCP Configuration (required for cloud operations)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_BUCKET_NAME=your-bucket-name
GCP_DATASET_ID=electrocardiograms

# Dataproc Configuration (optional - has defaults)
DATAPROC_CLUSTER_NAME=ekg-classifier-cluster
DATAPROC_NUM_WORKERS=2
DATAPROC_MASTER_MACHINE_TYPE=n1-standard-2
DATAPROC_WORKER_MACHINE_TYPE=n1-standard-2
DATAPROC_MASTER_BOOT_DISK_GB=30
DATAPROC_WORKER_BOOT_DISK_GB=30
DATAPROC_IMAGE_VERSION=2.1-debian11
DATAPROC_ENABLE_JUPYTER=true

# Model Configuration (optional - has defaults)
MODEL_HIDDEN_LAYERS=75,75,75
MODEL_MAX_ITER=300
MODEL_RANDOM_SEED=42
MODEL_BLOCK_SIZE=128
MODEL_BALANCE_CLASSES=true
MODEL_BALANCED_CLASS_SIZE=18000
